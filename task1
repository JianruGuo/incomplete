library(mice)

data <- read.csv("winequality-white.csv",sep=";")
head(data)
summary(data)


set.seed(1)
x <- data$alcohol
y <- data$density
cor(data$alcohol, data$pH)
n<-length(x)#4898 obs
length(y)#4898 obs

#check missingness
sum(is.na(x))
sum(is.na(y))

#impose MAR missingness to x
x_obs <-x
x_obs<-ifelse(y>median(y), NA, x_obs)
sum(is.na(x_obs))/n



simdata <- data.frame(y = y, x = x_obs)
cc_data <- cc(simdata)
#compare complete-case analysis with complete data (x~y)
model_complete <- lm(x ~ y)
summary(model_complete)

model_cc <- lm(x ~ y, data = cc_data)
summary(model_cc)

cbind(
  complete = coef(model_complete),
  complete_case = coef(model_cc)
)
par(mfrow=c(2,2))
plot(model_complete)

par(mfrow=c(2,2))
plot(model_cc)

#(y~x)
model_complete_1 <- lm(y ~ x)
summary(model_complete_1)

model_cc_1 <- lm(y ~ x, data = cc_data)
summary(model_cc_1)

cbind(
  complete = coef(model_complete_1),
  complete_case = coef(model_cc_1)
)
par(mfrow=c(2,2))
plot(model_complete_1)

par(mfrow=c(2,2))
plot(model_cc_1)


#apply stochastic regression imputation to x_obs
