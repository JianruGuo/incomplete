#for storage
R <- 100
intercept_cc <- numeric(R)
slope_cc <- numeric(R)
var_cc <- numeric(R)
cor_cc <- numeric(R)

intercept_sri <- numeric(R)
slope_sri <- numeric(R)
var_sri <- numeric(R)
cor_sri <- numeric(R)

intercept_pmm <- numeric(R)
slope_pmm <- numeric(R)
var_pmm <- numeric(R)
cor_pmm <- numeric(R)

for(i in 1:R){
  
  # --- create missing data ---
  x_obs <- x
  p <- plogis(3000*(y-mean(y)))
  miss <- rbinom(n,1,p)
  x_obs[miss==1] <- NA
  sum(is.na(x_obs))/n
  
  simdata <- data.frame(y=y,x=x_obs)
  cc_data <- cc(simdata)
  
  # --- complete case analysis ---
  model_cc <- lm(y ~ x, data=cc_data)
  
  intercept_cc[i] <- coef(model_cc)[1]
  slope_cc[i] <- coef(model_cc)[2]
  var_cc[i] <- summary(model_cc)$sigma^2
  cor_cc[i] <- cor(cc_data$x,cc_data$y)
  
  # --- stochastic regression imputation ---
  model_imp <- lm(x_obs ~ y)
  
  x_pred <- predict(model_imp)
  sigma <- summary(model_imp)$sigma
  
  x_imp <- x_obs
  miss <- is.na(x_obs)
  
  x_imp[miss] <- x_pred[miss] + rnorm(sum(miss),0,sigma)
  
  data_imp <- data.frame(y=y,x=x_imp)
  
  model_sri <- lm(y ~ x, data=data_imp)
  
  intercept_sri[i] <- coef(model_sri)[1]
  slope_sri[i] <- coef(model_sri)[2]
  var_sri[i] <- summary(model_sri)$sigma^2
  cor_sri[i] <- cor(x_imp,y)
  
  # --- predictive mean matching ---
  imps <- mice(simdata, method="pmm", printFlag=FALSE)
  
  com1 <- complete(imps,1)
  
  model_pmm <- lm(y ~ x, data=com1)
  
  intercept_pmm[i] <- coef(model_pmm)[1]
  slope_pmm[i] <- coef(model_pmm)[2]
  var_pmm[i] <- summary(model_pmm)$sigma^2
  cor_pmm[i] <- cor(com1$x,com1$y)
}



mean(slope_cc)
mean(slope_sri)
mean(slope_pmm)

sd(slope_cc)
sd(slope_sri)
sd(slope_pmm)

hist(slope_cc, main="CCA slope estimates")
abline(v=slope_complete,col="red",lwd=2)

hist(slope_sri, main="SRI slope estimates")
abline(v=slope_complete,col="red",lwd=2)

hist(slope_pmm, main="PMM slope estimates")
abline(v=slope_complete,col="red",lwd=2)

